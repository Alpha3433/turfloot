# Production Environment Configuration for TurfLoot
NODE_ENV=production
NEXT_PUBLIC_ENV=production

# Database Configuration (Atlas MongoDB will be provided by deployment)
# MONGO_URL will be provided by the deployment environment

# Application URLs  
# NEXT_PUBLIC_BASE_URL will be provided by the deployment environment

