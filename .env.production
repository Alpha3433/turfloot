NEXT_PUBLIC_PRIVY_APP_ID=cmdycgltk007ljs0bpjbjqx0a
PRIVY_APP_SECRET=LyLTdJkoLyVfUR44rxSJwnCB6dMC2xAV8WVXxRJtYK9YnJ4wTNBAzxxZaoAepAAGiAePcNoh16i42Aq9uXeYZWP

# Helius Configuration
HELIUS_API_KEY=af961c48-761a-4dc2-87ea-f734225b4e3b
NEXT_PUBLIC_HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=af961c48-761a-4dc2-87ea-f734225b4e3b
NEXT_PUBLIC_HELIUS_WEBSOCKET_URL=wss://devnet.helius-rpc.com/?api-key=af961c48-761a-4dc2-87ea-f734225b4e3b

# Ethereum Configuration  
ETHEREUM_RPC_URL=https://eth-mainnet.alchemyapi.io/v2/demo

# Game Configuration
NEXT_PUBLIC_GAME_MODE=multiplayer
NEXT_PUBLIC_MAX_PLAYERS=6
NEXT_PUBLIC_TICK_RATE=30

# Security
JWT_SECRET=turfloot-production-jwt-secret-change-this-in-deployment

# Features
NEXT_PUBLIC_FEATURES=multiplayer,blockchain,chat,achievements,customization,anti-cheat

# Performance  
NEXT_PUBLIC_CACHE_DURATION=300
NEXT_PUBLIC_MAX_CONNECTIONS=1000

# Solana Configuration
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Testing and Mock Configuration (disable in production)
NEXT_PUBLIC_TESTING_MODE=false
NEXT_PUBLIC_MOCK_WALLET_BALANCE=false

# Geo-blocking (disabled for now)
NEXT_PUBLIC_GEO_MODE=disabled

# Analytics
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Build optimization
NEXT_TELEMETRY_DISABLED=1
DISABLE_ESLINT_PLUGIN=true